{
  "manifest_version": 3,
  "name": "HelpViewer Help Integration",
  "version": "1.0",
  "permissions": ["scripting", "contextMenus", "activeTab"],
  "icons": {
    "32": "hvIcon32.png",
    "48": "hvIcon32.png"
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}